NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=focuslearn
JWT_SECRET=focuslearn-super-secret-jwt-key
JWT_REFRESH_SECRET=focuslearn-super-secret-refresh-key
