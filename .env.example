# Backend environment variables for Vercel deployment
NODE_ENV=production
PORT=5000

# Replace this with your MongoDB Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/focuslearn?retryWrites=true&w=majority

DB_NAME=focuslearn
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Add your frontend Vercel URL here
CORS_ORIGIN=https://your-frontend-app.vercel.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
